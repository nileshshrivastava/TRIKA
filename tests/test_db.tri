# ═══════════════════════════════════════════════════════════════
# TRIKA Phase 18 — trika.db Test
# Use "database" module + "conn" for handle variables
# ═══════════════════════════════════════════════════════════════
gyan trika.database
gyan trika.time

uvach("╔══════════════════════════════════════════════════╗")
uvach("║  TRIKA Phase 18 — trika.db Test                 ║")
uvach("╚══════════════════════════════════════════════════╝")
uvach("")

# ── MEMORY backend ───────────────────────────────────────
uvach("=== Backend: MEMORY ===")
trika conn = database.connect("", database.MEMORY)
uvach("handle: " + str(conn))

darshan(database.create_table(conn, "warriors",
    ["name", "army", "score", "guna"]))

# Insert 4 warriors
trika r1 = {}
add(r1, "name",  "Arjuna")
add(r1, "army",  "Pandava")
add(r1, "score", 95)
add(r1, "guna",  "SATTVA")
uvach("insert id: " + str(database.insert(conn, "warriors", r1)))

trika r2 = {}
add(r2, "name",  "Bhima")
add(r2, "army",  "Pandava")
add(r2, "score", 88)
add(r2, "guna",  "SATTVA")
database.insert(conn, "warriors", r2)

trika r3 = {}
add(r3, "name",  "Duryodhana")
add(r3, "army",  "Kaurava")
add(r3, "score", 72)
add(r3, "guna",  "TAMAS")
database.insert(conn, "warriors", r3)

trika r4 = {}
add(r4, "name",  "Karna")
add(r4, "army",  "Kaurava")
add(r4, "score", 91)
add(r4, "guna",  "RAJAS")
database.insert(conn, "warriors", r4)

uvach("count: " + str(database.count(conn, "warriors")))

# find all
trika all = database.find(conn, "warriors")
uvach("find all: " + str(len(all)) + " rows")

# find with where
trika wp = {}
add(wp, "army", "Pandava")
trika pandavas = database.find(conn, "warriors", wp)
uvach("Pandavas: " + str(len(pandavas)))
prati p in pandavas:
    uvach("  " + p["name"] + " score=" + p["score"])

# find_one
trika wa = {}
add(wa, "name", "Arjuna")
trika arjuna = database.find_one(conn, "warriors", wa)
yadi arjuna != RAJAS:
    uvach("find_one: " + arjuna["name"] + " score=" + arjuna["score"])
anyatha:
    uvach("find_one: not found")

# update
trika wk = {}
add(wk, "name", "Karna")
trika nd = {}
add(nd, "score", 93)
add(nd, "guna",  "SATTVA")
trika upd = database.update(conn, "warriors", wk, nd)
uvach("updated: " + str(upd) + " rows")

trika karna = database.find_one(conn, "warriors", wk)
yadi karna != RAJAS:
    uvach("Karna new score=" + karna["score"] + " guna=" + karna["guna"])

# delete
trika wd = {}
add(wd, "name", "Duryodhana")
uvach("deleted: " + str(database.delete(conn, "warriors", wd)) + " rows")
uvach("count after delete: " + str(database.count(conn, "warriors")))

# tables list
trika tbls = database.tables(conn)
uvach("tables: " + str(len(tbls)))
prati t in tbls:
    uvach("  " + t)

# transaction
uvach("--- transaction ---")
darshan(database.begin(conn))
trika r5 = {}
add(r5, "name",  "Nakula")
add(r5, "army",  "Pandava")
add(r5, "score", 78)
add(r5, "guna",  "SATTVA")
database.insert(conn, "warriors", r5)
darshan(database.commit(conn))
uvach("after commit: " + str(database.count(conn, "warriors")))

# SQL exec
trika sql_result = database.exec(conn, "SELECT * FROM warriors")
uvach("SQL SELECT rows: " + str(len(sql_result)))

darshan(database.close(conn))
uvach("Memory backend: DONE ✓")

# ── JSON backend ─────────────────────────────────────────
uvach("")
uvach("=== Backend: JSON ===")
trika jconn = database.connect("/tmp/trika_db_test", database.JSON)
darshan(database.create_table(jconn, "todos", ["title","status","date"]))

trika t1 = {}
add(t1, "title",  "Learn TRIKA")
add(t1, "status", "SATTVA")
add(t1, "date",   time.stamp())
database.insert(jconn, "todos", t1)

trika t2 = {}
add(t2, "title",  "Build trika.db")
add(t2, "status", "SATTVA")
add(t2, "date",   time.stamp())
database.insert(jconn, "todos", t2)

uvach("JSON count: " + str(database.count(jconn, "todos")))
darshan(database.save(jconn))
darshan(database.close(jconn))
uvach("JSON backend: DONE ✓")

# ── CSV backend ───────────────────────────────────────────
uvach("")
uvach("=== Backend: CSV ===")
trika cconn = database.connect("/tmp/trika_csv_test", database.CSV)
darshan(database.create_table(cconn, "scores", ["name","score","rank"]))

trika s1 = {}
add(s1, "name",  "Arjuna")
add(s1, "score", 95)
add(s1, "rank",  1)
database.insert(cconn, "scores", s1)

trika s2 = {}
add(s2, "name",  "Bhima")
add(s2, "score", 88)
add(s2, "rank",  2)
database.insert(cconn, "scores", s2)

uvach("CSV count: " + str(database.count(cconn, "scores")))
darshan(database.save(cconn))
darshan(database.close(cconn))
uvach("CSV backend: DONE ✓")

uvach("")
uvach("╔══════════════════════════════════════════════════╗")
uvach("║  trika.db Phase 18 — EXIT: 0                    ║")
uvach("║  Backends: MEMORY | JSON | CSV                   ║")
uvach("║  CRUD: insert find find_one update delete count  ║")
uvach("║  DDL:  create_table drop_table tables            ║")
uvach("║  TXN:  begin commit rollback save close          ║")
uvach("║  SQL:  exec query (SELECT INSERT DROP CREATE)    ║")
uvach("║  Hari Om Namah Shivaye 🕉️                        ║")
uvach("╚══════════════════════════════════════════════════╝")
