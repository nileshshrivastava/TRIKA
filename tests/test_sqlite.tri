# ═══════════════════════════════════════════════════════════════
# TRIKA Phase 19 — SQLite Backend Test — EXIT: 0
#
# Compile Linux:   gcc ... trika_db.c ... -DTRIKA_SQLITE -lsqlite3 -lm
# Compile Windows: gcc ... trika_db.c sqlite3.c ... -DTRIKA_SQLITE -lm -lws2_32
#
# Get sqlite3.c: https://sqlite.org/download.html
#   → sqlite-amalgamation-XXXXXXX.zip
#   → extract sqlite3.c + sqlite3.h into TRIKA folder
# ═══════════════════════════════════════════════════════════════
gyan trika.database

uvach("╔══════════════════════════════════════════════════╗")
uvach("║  TRIKA Phase 19 — SQLite Backend Test           ║")
uvach("╚══════════════════════════════════════════════════╝")
uvach("")

uvach("=== SQLite availability ===")
darshan(database.HAS_SQLITE)

uvach("")
uvach("=== connect + ping + info ===")
# NOTE: Use local path not /tmp/ on Windows
trika conn = database.connect("trika_p19.db", database.SQLITE)
uvach("handle: " + str(conn))
darshan(database.ping(conn))
trika inf = database.info(conn)
uvach("type:   " + inf["type"])
uvach("handle: " + str(inf["handle"]))

uvach("")
uvach("=== create_table ===")
trika cols = ["name", "army", "score", "guna"]
database.create_table(conn, "warriors", cols)
uvach("table created")

uvach("")
uvach("=== insert 4 warriors ===")
trika r1 = {}
add(r1, "name",  "Arjuna")
add(r1, "army",  "Pandava")
add(r1, "score", 95)
add(r1, "guna",  "SATTVA")
uvach("id: " + str(database.insert(conn, "warriors", r1)))

trika r2 = {}
add(r2, "name",  "Bhima")
add(r2, "army",  "Pandava")
add(r2, "score", 88)
add(r2, "guna",  "SATTVA")
uvach("id: " + str(database.insert(conn, "warriors", r2)))

trika r3 = {}
add(r3, "name",  "Duryodhana")
add(r3, "army",  "Kaurava")
add(r3, "score", 72)
add(r3, "guna",  "TAMAS")
uvach("id: " + str(database.insert(conn, "warriors", r3)))

trika r4 = {}
add(r4, "name",  "Karna")
add(r4, "army",  "Kaurava")
add(r4, "score", 91)
add(r4, "guna",  "RAJAS")
uvach("id: " + str(database.insert(conn, "warriors", r4)))

uvach("")
uvach("=== count ===")
uvach("count: " + str(database.count(conn, "warriors")))

uvach("")
uvach("=== exec SELECT all ===")
trika all_rows = database.exec(conn, "SELECT * FROM warriors")
uvach("rows: " + str(len(all_rows)))
prati row in all_rows:
    uvach("  id=" + str(row["id"]) + " name=" + row["name"] +
          " score=" + str(row["score"]))

uvach("")
uvach("=== find WHERE army=Pandava ===")
trika wp = {}
add(wp, "army", "Pandava")
trika pandavas = database.find(conn, "warriors", wp)
uvach("Pandavas: " + str(len(pandavas)))
prati p in pandavas:
    uvach("  " + p["name"] + " score=" + str(p["score"]))

uvach("")
uvach("=== find_one via find()[0] ===")
trika wa = {}
add(wa, "name", "Arjuna")
trika arjuna_list = database.find(conn, "warriors", wa)
uvach("Arjuna found: " + str(len(arjuna_list)))
yadi len(arjuna_list) > 0:
    trika arjuna = arjuna_list[0]
    uvach("  name=" + arjuna["name"] + " guna=" + arjuna["guna"])

uvach("")
uvach("=== update Karna ===")
trika wk = {}
add(wk, "name", "Karna")
trika nd = {}
add(nd, "score", 93)
add(nd, "guna",  "SATTVA")
uvach("updated: " + str(database.update(conn, "warriors", wk, nd)))

uvach("")
uvach("=== delete Duryodhana ===")
trika wd = {}
add(wd, "name", "Duryodhana")
uvach("deleted: " + str(database.delete(conn, "warriors", wd)))
uvach("count:   " + str(database.count(conn, "warriors")))

uvach("")
uvach("=== raw SQL WHERE ===")
trika top = database.exec(conn, "SELECT * FROM warriors WHERE score > 85")
uvach("score > 85: " + str(len(top)) + " warriors")
prati t in top:
    uvach("  " + t["name"] + " = " + str(t["score"]))

uvach("")
uvach("=== raw SQL ORDER BY ===")
trika ranked = database.exec(conn,
    "SELECT name, score FROM warriors ORDER BY score DESC")
uvach("ranked by score:")
prati r in ranked:
    uvach("  " + r["name"] + " = " + str(r["score"]))

uvach("")
uvach("=== transaction ===")
darshan(database.begin(conn))
trika r5 = {}
add(r5, "name",  "Nakula")
add(r5, "army",  "Pandava")
add(r5, "score", 78)
add(r5, "guna",  "SATTVA")
database.insert(conn, "warriors", r5)
darshan(database.commit(conn))
uvach("after commit: " + str(database.count(conn, "warriors")))

uvach("")
uvach("=== tables ===")
trika tbls = database.tables(conn)
uvach("table count: " + str(len(tbls)))
prati tbl in tbls:
    uvach("  " + tbl)

uvach("")
uvach("=== close ===")
darshan(database.close(conn))

uvach("")
uvach("=== verify persistence: reopen ===")
trika conn2 = database.connect("trika_p19.db", database.SQLITE)
uvach("rows after reopen: " + str(database.count(conn2, "warriors")))
trika persisted = database.exec(conn2,
    "SELECT name, score FROM warriors ORDER BY id")
prati row in persisted:
    uvach("  " + row["name"] + " score=" + str(row["score"]))
darshan(database.close(conn2))

uvach("")
uvach("╔══════════════════════════════════════════════════╗")
uvach("║  Phase 19 — SQLite — EXIT: 0                    ║")
uvach("║  CRUD + SQL + Transaction + Persistence         ║")
uvach("║  Hari Om Namah Shivaye 🕉️                        ║")
uvach("╚══════════════════════════════════════════════════╝")
