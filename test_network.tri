gyan trika.network

uvach("╔══════════════════════════════════════════════════╗")
uvach("║  TRIKA Phase 17 — trika.network — Pure C         ║")
uvach("║  Zero external dependencies. Raw sockets only.   ║")
uvach("╚══════════════════════════════════════════════════╝")
uvach("")

uvach("=== Configuration functions ===")
darshan(network.timeout(5000))
darshan(network.header("X-Trika", "Phase17"))
darshan(network.clear_headers())
darshan(network.base_url(""))
uvach("  All config functions: SATTVA ✓")

uvach("")
uvach("=== network.respond() ===")
trika r200 = network.respond(200, "Hari Om Namah Shivaye", "text/plain")
uvach("  status: " + str(r200["status"]))
uvach("  body:   " + r200["body"])
uvach("  ctype:  " + r200["content_type"])

trika r404 = network.respond(404, "Path not found", "text/plain")
uvach("  404 status: " + str(r404["status"]))

trika r500 = network.respond(500, "{\"error\":\"Internal\"}", "application/json")
uvach("  500 status: " + str(r500["status"]))

uvach("")
uvach("=== Guna HTTP semantics ===")
uvach("  HTTP 2xx → SATTVA (+1) success")
uvach("  HTTP 3xx → RAJAS  ( 0) redirect")
uvach("  HTTP 4xx → TAMAS  (-1) client error")
uvach("  HTTP 5xx → TAMAS  (-1) server error")

uvach("")
uvach("=== network.get() — live HTTP test ===")
trika resp = network.get("http://httpbin.org/get")
uvach("  status: " + str(resp["status"]))
darshan(resp["ok"])
yadi resp["ok"] == SATTVA:
    uvach("  body[:60]: " + slice(resp["body"], 0, 60))
anyatha:
    uvach("  (network not available in this environment)")

uvach("")
uvach("=== network.post() ===")
trika resp2 = network.post("http://httpbin.org/post", "lang=TRIKA&guna=SATTVA")
uvach("  status: " + str(resp2["status"]))
darshan(resp2["ok"])

uvach("")
uvach("=== network.post_json() ===")
trika resp3 = network.post_json("http://httpbin.org/post",
    "{\"lang\":\"TRIKA\",\"phase\":17,\"guna\":\"SATTVA\"}")
uvach("  status: " + str(resp3["status"]))
darshan(resp3["ok"])

uvach("")
uvach("=== network.status() ===")
trika code = network.status("http://httpbin.org/status/200")
uvach("  status code: " + str(code))

uvach("")
uvach("=== Server handler karma ===")
karma dharma_handler(trika req):
    trika method = req["method"]
    trika path   = req["path"]
    uvach("  Request: " + method + " " + path)
    yadi path == "/":
        phal network.respond(200,
            "Hari Om Namah Shivaye! TRIKA Server Phase 17",
            "text/plain")
    anyatha:
        yadi path == "/guna":
            phal network.respond(200,
                "{\"SATTVA\":1,\"RAJAS\":0,\"TAMAS\":-1}",
                "application/json")
        anyatha:
            phal network.respond(404,
                "Not found: " + path,
                "text/plain")

uvach("  Handler karma defined ✓")
uvach("  To start: network.serve(8080, \"dharma_handler\")")
uvach("  Test:     curl http://localhost:8080/")
uvach("            curl http://localhost:8080/guna")
uvach("")
uvach("  NOTE: HTTPS → needs libcurl (add -lcurl to compile)")
uvach("        HTTP  → pure C raw sockets, zero dependencies")
uvach("")
uvach("╔══════════════════════════════════════════════════╗")
uvach("║  trika.network Phase 17 — Pure C — EXIT: 0      ║")
uvach("║  Compile: gcc ... trika_network.c ... -lm       ║")
uvach("║  Windows: gcc ... trika_network.c ... -lm -lws2_32 ║")
uvach("║  Hari Om Namah Shivaye 🕉️                        ║")
uvach("╚══════════════════════════════════════════════════╝")
